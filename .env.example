# ═══════════════════════════════════════════════
# Dairy API - Environment Variables
# Copy this file to .env and fill in the values
# ═══════════════════════════════════════════════

# ── SQL Server Connections ──
ConnectionStrings__Cross=Server=YOUR_SERVER;Database=Cross;User Id=userCrossLoads;Password=YOUR_PASS;Encrypt=True;TrustServerCertificate=True;
ConnectionStrings__GeneralDairyi=Server=YOUR_SERVER;Database=General_Dairyi;User Id=sqluser;Password=YOUR_PASS;Encrypt=True;TrustServerCertificate=True;
ConnectionStrings__General=Server=YOUR_SERVER;Database=General;User Id=sqluser;Password=YOUR_PASS;Encrypt=True;TrustServerCertificate=True;
ConnectionStrings__ApprovalProd=Server=YOUR_SERVER;Database=Approval_Prod;User Id=sqluser;Password=YOUR_PASS;Encrypt=True;TrustServerCertificate=True;
ConnectionStrings__iScaleOutlier=Server=YOUR_SERVER;Database=iScale_Outlier;User Id=userDairyi_Outlier;Password=YOUR_PASS;Encrypt=True;TrustServerCertificate=True;
ConnectionStrings__ICCManager=Server=YOUR_SERVER2;Database=ICCManager;User Id=userScalei;Password=YOUR_PASS;Encrypt=True;TrustServerCertificate=True;

# ── FTP ──
Ftp__Host=YOUR_FTP_HOST
Ftp__User=YOUR_FTP_USER
Ftp__Password=YOUR_FTP_PASSWORD
Ftp__BasePath=/images

# ── Keycloak ──
KEYCLOAK_ADMIN_PASSWORD=ChangeMe123!
KC_DB_PASSWORD=keycloakpass

# ── CORS ──
AllowedOrigins__0=https://app.tuempresa.com
